# Backend origin used by Next.js server route handlers.
# Set this to the current CloudFront URL in production.
API_BASE_URL=http://localhost:5148

# Values from: terraform output cognito_user_pool_id / cognito_client_id
COGNITO_USER_POOL_ID=ap-southeast-1_example
COGNITO_CLIENT_ID=your-cognito-app-client-id
